<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScreen" extends="Group" focusable="true">
    <script type="text/brightscript" uri="pkg:/components/Screens/HomeScreen.brs" />
    
    <interface>
        <field id="activeScreen" type="string" alwaysNotify="true" />
    </interface>

    <children>
        
        <Label id="startLabel" text="PRESS OK TO START" translation="[500, 350]" color="0xFFFFFFFF" font="font:LargeBoldSystemFont" />

        <Poster id="gpsComponent" uri="pkg:/images/gps.jpg" width="199" height="720" translation="[0, 0]" />



        <Group id="centerRoadScroller" translation="[199, 0]">
            <Poster id="roadLoop2" uri="pkg:/images/road/road.jpg" width="764" height="720" translation="[0, -720]" />
            <Poster id="roadLoop1" uri="pkg:/images/road/Striproad.jpg" width="764" height="720" translation="[0, 0]" />

            <Rectangle id="foot1" width="2" height="720" color="0xFF0000FF" translation="[186, 0]" visible="false" />
            <Rectangle id="foot2" width="2" height="720" color="0xFF0000FF" translation="[558, 0]" visible="false" />

            <Group id="obstaclesGroup">
                <Group id="obs1" translation="[250, -150]">
                    <Poster id="obs1Image" uri="pkg:/images/cars/car1.jpg" width="80" height="105" />
                    <Rectangle id="obs1Hitbox" width="55" height="96" translation="[9, 5]" color="0xFF000088" visible="false" />
                </Group>
                <Group id="obs2" translation="[250, -600]">
                    <Poster id="obs2Image" uri="pkg:/images/cars/truck.jpg" width="73" height="143" />
                    <Rectangle id="obs2Hitbox" width="60" height="137" translation="[5, 5]" color="0xFF000088" visible="false" />
                </Group>
            </Group>

            <Group id="playerCarGroup" translation="[250, 500]">
                <Poster id="playerCarImage" uri="pkg:/images/cars/maincar.jpg" width="78" height="107" rotationPivot="[39, 53]">
                    <Animation id="spinAnim" duration="0.5" repeatCount="0" control="stop">
                        <FloatFieldInterpolator id="spinInterp" key="[0.0, 1.0]" keyValue="[0.0, 6.28318]" fieldToInterp="playerCarImage.rotation" />
                    </Animation>
                </Poster>
                <Rectangle id="playerHitbox" width="53" height="90" translation="[9, 7]" color="0x00FF0088" visible="fasle" />
            </Group>

            <Poster id="explosionSprite" uri="pkg:/images/blasting/f1.jpg" width="80" height="80" visible="false" />
            
            <Label id="gameOverLabel" text="GAME OVER" translation="[90, 350]" color="0xFF0000FF" visible="false" font="font:LargeBoldSystemFont" />
        </Group>

        

        <Group id="progressTracker" translation="[953, 0]">
            <Rectangle width="327" height="720" color="0x222222FF" />
            <Label id="speedLabel" text="Speed: 0" translation="[20, 50]" color="0xFFFFFFFF" font="font:MediumBoldSystemFont" />
            <Label id="timeLabel" text="Time: 60" translation="[20, 200]" color="0xFFFFFFFF" font="font:MediumBoldSystemFont" />
        </Group>

        <Timer id="gameTimer" repeat="true" duration="0.016" /> 
        <Timer id="explosionTimer" repeat="true" duration="0.1" control="stop" />
    </children>


</component>