<component name="GameScreen" extends="Group" focusable="true">
    <script type="text/brightscript" uri="pkg:/components/Screens/GameScreen.brs"/>
    <interface>
        <field id="activeScreen" type="string" alwaysNotify="true"/>
    </interface>

    <children>
        <Poster uri="pkg:/images/game_bg.jpg" width="1280" height="720"/>

        <Poster id="ground1" uri="pkg:/images/ground.jpg" width="1280" height="240" translation="[0, 520]" />
        <Poster id="ground2" uri="pkg:/images/ground.jpg" width="1280" height="240" translation="[1280, 520]" />
        
        <Poster id="cloud2a" uri="pkg:/images/cloud_2.jpg" width="320" height="140" translation="[400, 120]" loadDisplayMode="scaleToFit"/>
        <Poster id="cloud2b" uri="pkg:/images/cloud_2.jpg" width="320" height="140" translation="[1100, 120]" loadDisplayMode="scaleToFit"/>
        <Poster id="cloud1a" uri="pkg:/images/cloud_1.jpg" width="220" height="100" translation="[100, 30]" loadDisplayMode="scaleToFit"/>
        <Poster id="cloud1b" uri="pkg:/images/cloud_1.jpg" width="220" height="100" translation="[850, 30]" loadDisplayMode="scaleToFit"/>
        
        <Rectangle id="obstacleCollider" color="0x00000000" width="90" height="150" translation="[1280, 520]">
            <Poster id="obstacleBox1" uri="pkg:/images/ob1.jpg" width="90" height="180" translation="[-20,0]" visible="true" loadSync="true" />
            <Poster id="obstacleBox2" uri="pkg:/images/ob2.jpg" width="100" height="180" translation="[-20,-40]" visible="false" loadSync="true" />
            <Poster id="obstacleBox3" uri="pkg:/images/ob3.jpg" width="140" height="140" translation="[0,0]" visible="false" loadSync="true" />
            <Poster id="obstacleBox4" uri="pkg:/images/ob4.jpg" width="100" height="100" translation="[-20,0]" visible="false" loadSync="true" />
        </Rectangle>

        
        
        <Rectangle id="playerCollider" color="0x00000000" width="70" height="70" translation="[200, 520]">
            <Poster id="playerBox" uri="pkg:/images/dinorun/f1.jpg" width="320" height="230" translation="[-180, -80]" loadDisplayMode="scaleToFit" loadSync="true"/>
        </Rectangle>

        <Poster id="coinBox" uri="pkg:/images/coin.jpg" width="50" height="50" translation="[1500, 400]" loadSync="true"/>
        
        <Label id="scoreLabel" text="SCORE: 0" width="300" height="50" translation="[950, 30]" color="0x000000" font="font:LargeBoldSystemFont"/>
        <Timer id="gameTimer" duration="0.016" repeat="true"/>
        <GameOverPopup id="popup" visible="false"/>
    </children>
</component>