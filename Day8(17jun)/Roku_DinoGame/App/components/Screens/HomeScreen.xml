<?xml version="1.0" encoding="utf-8" ?>
<component name="homescreen" extends="Group" focusable="true">

    <script type="text/brightscript" uri="pkg:/components/Screens/HomeScreen.brs" />
    
    <interface>
        <field id="activeScreen" type="string" alwaysNotify="true" />
    </interface>

    <children>
        <Poster id="background" uri="pkg:/images/jungle_bg.jpg" width="1280" height="720" />
        
        <Group id="playGroup" translation="[490, 250]">
            <Rectangle id="playBtn" width="300" height="100" color="0x32CD32FF" />
            <Label text="PLAY" width="300" height="100" horizAlign="center" vertAlign="center" color="0xFFFFFFFF" font="font:LargeBoldSystemFont" />
        </Group>

        <Group id="shopGroup" translation="[490, 400]">
            <Rectangle id="shopBtn" width="300" height="100" color="0x1E5631FF" />
            <Label text="SHOP" width="300" height="100" horizAlign="center" vertAlign="center" color="0xFFFFFFFF" font="font:LargeBoldSystemFont" />
        </Group>
    </children>

</component>